# ── App ───────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# ── Database (PostgreSQL) ────────────────────────────────────────────
# On Vercel, use a serverless-friendly Postgres provider (Neon, Supabase, or
# Vercel Postgres). DATABASE_URL must point at the POOLED connection
# (pgbouncer) — Prisma reuses this on every serverless invocation.
# DIRECT_URL must point at the UNPOOLED connection — Prisma uses it only for
# `migrate`/`db push`, which need a real session-level connection.
# Local/single-instance Postgres: both can be the same value.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/quick_solutions?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/quick_solutions?schema=public"

# ── Sessions (connect-pg-simple — sessions live in the `session` table) ─
# Generate strong secrets, e.g.: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-with-a-long-random-string
# Default session lifetime in ms (unchecked "Remember me"). Default: 1 day.
SESSION_MAX_AGE_MS=86400000
# Session lifetime in ms when "Remember me" is checked. Default: 30 days.
REMEMBER_ME_MAX_AGE_MS=2592000000

# ── CSRF (double-submit cookie — see middleware/csrf.js) ────────────
# Use a DIFFERENT random value than SESSION_SECRET.
CSRF_SECRET=replace-with-a-different-long-random-string

# ── Cloudinary (product, category, brand & avatar image storage) ────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Company / Business Info ──────────────────────────────────────────
COMPANY_NAME="Mequick Solutions"
COMPANY_PHONE="+254 725 421 131"
