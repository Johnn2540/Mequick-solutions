COMPANY_EMAIL="mequicksolutions8@gmail.com"
COMPANY_ADDRESS="AXIOM ONE EXHIBITION, First Floor, Shop 53, Opposite Gill House, Near Afya Centre, Along Tom Mboya Street, Nairobi, Kenya"
