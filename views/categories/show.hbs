<section class="py-5">
  <div class="container">
    {{#if category.images.length}}
      <div class="mb-4 rounded-3 overflow-hidden shadow-sm">
        {{#gt category.images.length 1}}
          <div id="categoryGallery" class="carousel slide" data-bs-ride="false">
            <div class="carousel-inner">
              {{#each category.images}}
                <div class="carousel-item {{#eq @index 0}}active{{/eq}}">
                  <img src="{{this.url}}" class="d-block w-100 category-hero-img" alt="{{../category.name}}">
                </div>
              {{/each}}
            </div>
            <button class="carousel-control-prev" type="button" data-bs-target="#categoryGallery" data-bs-slide="prev">
              <span class="carousel-control-prev-icon"></span>
            </button>
            <button class="carousel-control-next" type="button" data-bs-target="#categoryGallery" data-bs-slide="next">
              <span class="carousel-control-next-icon"></span>
            </button>
          </div>
        {{else}}
          <img src="{{category.images.[0].url}}" class="d-block w-100 category-hero-img" alt="{{category.name}}">
        {{/gt}}
      </div>
    {{/if}}

    <div class="mb-5">
      <h1 class="fw-bold">{{category.name}}</h1>
      {{#if category.description}}
        <p class="text-muted col-lg-8">{{category.description}}</p>
      {{/if}}
      <span class="text-muted small">{{pagination.totalCount}} product(s) in this category</span>
    </div>

    {{#if products.length}}
      <div class="row g-3">
        {{#each products}}
          {{> product_card}}
        {{/each}}
      </div>
      {{> pagination baseUrl=(concat "/categories/" category.slug)}}
    {{else}}
      <div class="text-center py-5">
        <i class="bi bi-box-seam display-4 text-muted"></i>
        <p class="text-muted mt-3">No products in this category yet. Check back soon.</p>
        <a href="/products" class="btn btn-outline-primary">Browse All Products</a>
      </div>
    {{/if}}
  </div>
</section>
