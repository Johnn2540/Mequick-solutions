<div class="row g-4 mb-4">
  <div class="col-lg-3 col-md-6">
    <div class="card border-0 shadow-sm">
      <div class="card-body d-flex align-items-center gap-3">
        <div class="stat-icon bg-primary-subtle text-primary"><i class="bi bi-box-seam"></i></div>
        <div>
          <h3 class="fw-bold mb-0">{{stats.productCount}}</h3>
          <span class="text-muted small">Products</span>
        </div>
      </div>
    </div>
  </div>
  <div class="col-lg-3 col-md-6">
    <div class="card border-0 shadow-sm">
      <div class="card-body d-flex align-items-center gap-3">
        <div class="stat-icon bg-success-subtle text-success"><i class="bi bi-grid-3x3-gap"></i></div>
        <div>
          <h3 class="fw-bold mb-0">{{stats.categoryCount}}</h3>
          <span class="text-muted small">Categories</span>
        </div>
      </div>
    </div>
  </div>
  <div class="col-lg-3 col-md-6">
    <div class="card border-0 shadow-sm">
      <div class="card-body d-flex align-items-center gap-3">
        <div class="stat-icon bg-info-subtle text-info"><i class="bi bi-tags"></i></div>
        <div>
          <h3 class="fw-bold mb-0">{{stats.brandCount}}</h3>
          <span class="text-muted small">Brands</span>
        </div>
      </div>
    </div>
  </div>
  <div class="col-lg-3 col-md-6">
    <div class="card border-0 shadow-sm">
      <div class="card-body d-flex align-items-center gap-3">
        <div class="stat-icon bg-warning-subtle text-warning"><i class="bi bi-exclamation-triangle"></i></div>
        <div>
          <h3 class="fw-bold mb-0">{{stats.outOfStockCount}}</h3>
          <span class="text-muted small">Out of Stock</span>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="row g-4 mb-4">
  <div class="col-lg-3 col-md-6">
    <a href="/admin/quotes" class="card stat-card-link border-0 shadow-sm text-decoration-none">
      <div class="card-body d-flex align-items-center gap-3">
        <div class="stat-icon bg-primary-subtle text-primary"><i class="bi bi-file-earmark-text"></i></div>
        <div>
          <h3 class="fw-bold mb-0 text-dark">{{stats.quoteCount}}</h3>
          <span class="text-muted small">Quote Requests ({{stats.pendingQuoteCount}} pending)</span>
        </div>
      </div>
    </a>
  </div>
  <div class="col-lg-3 col-md-6">
    <a href="/admin/enquiries" class="card stat-card-link border-0 shadow-sm text-decoration-none">
      <div class="card-body d-flex align-items-center gap-3">
        <div class="stat-icon bg-success-subtle text-success"><i class="bi bi-chat-dots"></i></div>
        <div>
          <h3 class="fw-bold mb-0 text-dark">{{stats.enquiryCount}}</h3>
          <span class="text-muted small">Enquiries ({{stats.newEnquiryCount}} new)</span>
        </div>
      </div>
    </a>
  </div>
  <div class="col-lg-3 col-md-6">
    <a href="/admin/messages" class="card stat-card-link border-0 shadow-sm text-decoration-none">
      <div class="card-body d-flex align-items-center gap-3">
        <div class="stat-icon bg-info-subtle text-info"><i class="bi bi-envelope"></i></div>
        <div>
          <h3 class="fw-bold mb-0 text-dark">{{stats.messageCount}}</h3>
          <span class="text-muted small">Messages ({{stats.unreadMessageCount}} unread)</span>
        </div>
      </div>
    </a>
  </div>
  <div class="col-lg-3 col-md-6">
    <a href="/admin/inventory?lowStock=1" class="card stat-card-link border-0 shadow-sm text-decoration-none">
      <div class="card-body d-flex align-items-center gap-3">
        <div class="stat-icon bg-danger-subtle text-danger"><i class="bi bi-exclamation-diamond"></i></div>
        <div>
          <h3 class="fw-bold mb-0 text-dark">{{stats.lowStockCount}}</h3>
          <span class="text-muted small">Low Stock Alerts</span>
        </div>
      </div>
    </a>
  </div>
</div>

<div class="row g-4 mb-4">
  <div class="col-lg-8">
    <div class="card border-0 shadow-sm">
      <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <h6 class="fw-bold mb-0">Recent Products</h6>
        <a href="/admin/products" class="small">View All</a>
      </div>
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th>Product</th>
              <th>Category</th>
              <th>Availability</th>
              <th>Added</th>
            </tr>
          </thead>
          <tbody>
            {{#each recentProducts}}
              <tr>
                <td class="d-flex align-items-center gap-2">
                  {{#if this.images.[0].url}}
                    <img src="{{this.images.[0].url}}" class="admin-thumb" alt="{{this.name}}">
                  {{else}}
                    <div class="admin-thumb bg-light d-flex align-items-center justify-content-center">
                      <i class="bi bi-image text-muted"></i>
                    </div>
                  {{/if}}
                  <a href="/admin/products/{{this.id}}/edit" class="text-decoration-none">{{this.name}}</a>
                </td>
                <td>{{this.category.name}}</td>
                <td>
                  {{#eq this.availability 'IN_STOCK'}}<span class="badge text-bg-success">In Stock</span>{{/eq}}
                  {{#eq this.availability 'OUT_OF_STOCK'}}<span class="badge text-bg-secondary">Out of Stock</span>{{/eq}}
                  {{#eq this.availability 'PREORDER'}}<span class="badge text-bg-warning">Pre-order</span>{{/eq}}
                </td>
                <td class="text-muted small">{{formatDate this.createdAt}}</td>
              </tr>
            {{else}}
              <tr><td colspan="4" class="text-center text-muted py-4">No products yet.</td></tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <div class="col-lg-4">
    <div class="card border-0 shadow-sm mb-4">
      <div class="card-header bg-white"><h6 class="fw-bold mb-0">Quick Actions</h6></div>
      <div class="list-group list-group-flush">
        <a href="/admin/products/new" class="list-group-item list-group-item-action">
          <i class="bi bi-plus-circle me-2 text-primary"></i>Add New Product
        </a>
        <a href="/admin/categories/new" class="list-group-item list-group-item-action">
          <i class="bi bi-plus-circle me-2 text-primary"></i>Add New Category
        </a>
        <a href="/admin/brands/new" class="list-group-item list-group-item-action">
          <i class="bi bi-plus-circle me-2 text-primary"></i>Add New Brand
        </a>
      </div>
    </div>

    <div class="card border-0 shadow-sm">
      <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <h6 class="fw-bold mb-0">Low Stock Alerts</h6>
        <a href="/admin/inventory?lowStock=1" class="small">View All</a>
      </div>
      <div class="list-group list-group-flush">
        {{#each lowStockProducts}}
          <a href="/admin/inventory/{{this.id}}/history" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
            <span>
              {{this.name}}
              <span class="text-muted small d-block">{{this.category.name}}</span>
            </span>
            <span class="badge text-bg-danger">{{this.stockQuantity}} left</span>
          </a>
        {{else}}
          <div class="list-group-item text-muted small">No low stock products right now.</div>
        {{/each}}
      </div>
    </div>
  </div>
</div>

<div class="card border-0 shadow-sm">
  <div class="card-header bg-white"><h6 class="fw-bold mb-0">Recent Uploads</h6></div>
  <div class="card-body">
    {{#if recentUploads.length}}
      <div class="d-flex flex-wrap gap-3">
        {{#each recentUploads}}
          <a href="/admin/products/{{this.productId}}/edit" class="text-decoration-none" title="{{this.product.name}}">
            <img src="{{this.url}}" class="admin-image-preview" alt="{{this.product.name}}">
          </a>
        {{/each}}
      </div>
    {{else}}
      <p class="text-muted mb-0">No images uploaded yet.</p>
    {{/if}}
  </div>
</div>
