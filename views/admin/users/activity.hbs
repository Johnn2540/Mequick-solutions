<div class="mb-4">
  <a href="/admin/users" class="text-decoration-none small"><i class="bi bi-arrow-left me-1"></i>Back to Users</a>
</div>

<div class="row g-4 mb-4">
  <div class="col-lg-4">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body text-center">
        {{#if user.avatarUrl}}
          <img src="{{user.avatarUrl}}" class="rounded-circle mb-3" alt="{{user.name}}" style="width: 96px; height: 96px; object-fit: cover;">
        {{else}}
          <div class="rounded-circle bg-primary-subtle text-primary d-flex align-items-center justify-content-center mx-auto mb-3" style="width: 96px; height: 96px; font-size: 2rem;">
            <i class="bi bi-person"></i>
          </div>
        {{/if}}
        <h6 class="fw-bold mb-0">{{user.name}}</h6>
        <p class="text-muted small mb-2">{{user.email}}</p>
        <span class="badge text-bg-primary">{{user.role}}</span>
        {{#if user.isActive}}
          <span class="badge text-bg-success">Active</span>
        {{else}}
          <span class="badge text-bg-secondary">Inactive</span>
        {{/if}}
        <div class="mt-3">
          <a href="/admin/users/{{user.id}}/edit" class="btn btn-sm btn-outline-primary">
            <i class="bi bi-pencil me-1"></i>Edit User
          </a>
        </div>
      </div>
    </div>
  </div>

  <div class="col-lg-8">
    <div class="row g-3 h-100">
      <div class="col-md-6">
        <div class="card border-0 shadow-sm h-100">
          <div class="card-body">
            <dl class="row mb-0 small">
              <dt class="col-6 text-muted fw-normal">Last Login</dt>
              <dd class="col-6 mb-2">{{#if user.lastLogin}}{{formatDate user.lastLogin}}{{else}}Never{{/if}}</dd>
              <dt class="col-6 text-muted fw-normal">Last Logout</dt>
              <dd class="col-6 mb-2">{{#if lastLogout}}{{formatDate lastLogout}}{{else}}—{{/if}}</dd>
              <dt class="col-6 text-muted fw-normal">Last Active</dt>
              <dd class="col-6 mb-2">{{#if lastActive}}{{formatDate lastActive}}{{else}}Never{{/if}}</dd>
              <dt class="col-6 text-muted fw-normal">Member Since</dt>
              <dd class="col-6 mb-0">{{formatDate user.createdAt}}</dd>
            </dl>
          </div>
        </div>
      </div>
      <div class="col-md-6">
        <div class="row g-3">
          <div class="col-6">
            <div class="card border-0 shadow-sm h-100">
              <div class="card-body text-center">
                <div class="stat-icon bg-primary-subtle text-primary mx-auto mb-2"><i class="bi bi-box-arrow-in-right"></i></div>
                <h4 class="fw-bold mb-0">{{totalLoginCount}}</h4>
                <span class="text-muted small">Total Logins</span>
              </div>
            </div>
          </div>
          <div class="col-6">
            <div class="card border-0 shadow-sm h-100">
              <div class="card-body text-center">
                <div class="stat-icon bg-success-subtle text-success mx-auto mb-2"><i class="bi bi-activity"></i></div>
                <h4 class="fw-bold mb-0">{{totalActions}}</h4>
                <span class="text-muted small">Total Actions</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="card border-0 shadow-sm">
  <div class="card-header bg-white"><h6 class="fw-bold mb-0">Recent Activity</h6></div>
  <div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
      <thead class="table-light">
        <tr>
          <th>When</th>
          <th>Module</th>
          <th>Action</th>
          <th>Description</th>
          <th>Status</th>
          <th>IP Address</th>
        </tr>
      </thead>
      <tbody>
        {{#each logs}}
          <tr>
            <td class="small text-muted text-nowrap">{{formatDate this.createdAt}}</td>
            <td class="small text-muted">{{#if this.module}}{{this.module}}{{else}}—{{/if}}</td>
            <td><span class="badge text-bg-{{auditBadgeClass this.action}}">{{this.action}}</span></td>
            <td>{{this.description}}</td>
            <td>
              {{#eq this.status 'FAILED'}}
                <span class="badge text-bg-danger">Failed</span>
              {{else}}
                <span class="badge text-bg-success">Success</span>
              {{/eq}}
            </td>
            <td class="small text-muted">{{this.ipAddress}}</td>
          </tr>
        {{else}}
          <tr><td colspan="6" class="text-center text-muted py-4">No activity recorded for this user yet.</td></tr>
        {{/each}}
      </tbody>
    </table>
  </div>
</div>

{{> pagination baseUrl=(concat "/admin/users/" user.id "/activity") filters=(hash)}}
