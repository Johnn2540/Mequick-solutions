<div class="row">
  <div class="col-lg-6">
    <form method="POST" action="{{formAction}}" {{#if targetUser}}data-original-role="{{targetUser.role}}"{{/if}}>
      {{> csrf}}
      <div class="card border-0 shadow-sm">
        <div class="card-body">
          {{#if isSelf}}
            <div class="alert alert-info small">
              <i class="bi bi-info-circle me-1"></i>You're editing your own account — role and active status can't be changed here. Use <a href="/admin/profile">My Profile</a> for your own name, email, or password.
            </div>
          {{/if}}

          <div class="mb-3">
            <label for="name" class="form-label">Full Name *</label>
            <input type="text" id="name" name="name" class="form-control" value="{{targetUser.name}}" required>
          </div>

          <div class="mb-3">
            <label for="email" class="form-label">Email *</label>
            <input type="email" id="email" name="email" class="form-control" value="{{targetUser.email}}" required>
          </div>

          {{#unless targetUser}}
            <div class="mb-3">
              <label for="password" class="form-label">Password *</label>
              <input type="password" id="password" name="password" class="form-control" required>
              <div class="form-text">At least 8 characters, with uppercase, lowercase, a number, and a special character.</div>
            </div>
          {{/unless}}

          <div class="mb-3">
            <label for="role" class="form-label">Role *</label>
            <select id="role" name="role" class="form-select" required>
              {{#each roles}}
                <option value="{{this}}" {{#eq this ../targetUser.role}}selected{{/eq}}>{{this}}</option>
              {{/each}}
            </select>
          </div>

          {{#if targetUser}}
            <div class="form-check mb-3">
              <input class="form-check-input" type="checkbox" id="isActive" name="isActive" {{#if targetUser.isActive}}checked{{/if}}>
              <label class="form-check-label" for="isActive">Account is active</label>
            </div>
          {{/if}}

          <button type="submit" class="btn btn-primary px-4">{{#if targetUser}}Update User{{else}}Create User{{/if}}</button>
          <a href="/admin/users" class="btn btn-outline-secondary px-4">Cancel</a>
        </div>
      </div>
    </form>

    {{#if targetUser}}
      <div class="card border-0 shadow-sm mt-4">
        <div class="card-body">
          <h6 class="fw-bold mb-2">Reset Password</h6>
          <p class="text-muted small mb-3">Generates a new random password for this user immediately. It's shown once — copy it and share it with them securely.</p>
          <form method="POST" action="/admin/users/{{targetUser.id}}/reset-password" data-confirm="Reset this user's password? Their current password will stop working immediately.">
            {{> csrf}}
            <button type="submit" class="btn btn-outline-danger btn-sm">
              <i class="bi bi-key me-1"></i>Reset Password
            </button>
          </form>
        </div>
      </div>
    {{/if}}
  </div>
</div>
