<div class="card border-0 shadow login-card">
  <div class="card-body p-4 p-md-5">
    <div class="text-center mb-4">
      <a href="/" class="d-inline-block mb-3">
        <img src="/images/logo.png" alt="{{company.name}}" class="login-logo">
      </a>
      <h4 class="fw-bold mb-1">Admin Login</h4>
      <p class="text-muted small mb-0">Sign in to the {{company.name}} management panel</p>
    </div>

    <form method="POST" action="/admin/login">
      {{> csrf}}
      <div class="mb-3">
        <label for="email" class="form-label">Email</label>
        <input type="email" id="email" name="email" class="form-control" required autofocus>
      </div>
      <div class="mb-3">
        <div class="d-flex justify-content-between align-items-center mb-1">
          <label for="password" class="form-label mb-0">Password</label>
          <a href="#" class="small text-decoration-none" data-bs-toggle="modal" data-bs-target="#forgotPasswordModal">
            Forgot password?
          </a>
        </div>
        <input type="password" id="password" name="password" class="form-control" required>
      </div>
      <div class="mb-4 form-check">
        <input type="checkbox" class="form-check-input" id="rememberMe" name="rememberMe">
        <label class="form-check-label" for="rememberMe">Remember me for 30 days</label>
      </div>
      <button type="submit" class="btn btn-primary w-100 py-2 fw-semibold">
        <i class="bi bi-box-arrow-in-right me-2"></i>Sign In
      </button>
    </form>

    <div class="text-center mt-4 pt-3 border-top">
      <p class="small text-muted mb-1">
        <i class="bi bi-shield-lock-fill me-1"></i>Secure access — all activity is logged.
      </p>
      <a href="/" class="small text-decoration-none">
        <i class="bi bi-arrow-left me-1"></i>Back to website
      </a>
    </div>
  </div>
</div>

<!-- No self-service reset yet — this system has no email delivery
     configured, so a real "reset link sent to your inbox" flow would be
     a lie. Points admins to the one reset path that actually exists
     today: a Super Admin resetting a user's password from Admin →
     Users. -->
<div class="modal fade" id="forgotPasswordModal" tabindex="-1" aria-labelledby="forgotPasswordModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="forgotPasswordModalLabel">Forgot Your Password?</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <p class="mb-3">
          For security, passwords can only be reset by a Super Administrator from within the admin panel.
          Reach out to one directly and they'll reset it for you.
        </p>
        <div class="d-grid gap-2">
          <a
            href="{{waLink company.whatsapp 'Hi, I need help resetting my password for the admin panel.'}}"
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn-success"
          >
            <i class="bi bi-whatsapp me-2"></i>Message on WhatsApp
          </a>
          <a href="mailto:{{company.email}}" class="btn btn-outline-secondary">
            <i class="bi bi-envelope me-2"></i>Email {{company.email}}
          </a>
        </div>
      </div>
    </div>
  </div>
</div>
