<div class="d-flex justify-content-between align-items-center mb-4">
  <h6 class="text-muted mb-0">{{categories.length}} categories</h6>
  <a href="/admin/categories/new" class="btn btn-primary"><i class="bi bi-plus-circle me-1"></i>Add Category</a>
</div>

<div class="card border-0 shadow-sm">
  <div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
      <thead class="table-light">
        <tr>
          <th>Category</th>
          <th>Slug</th>
          <th>Products</th>
          <th class="text-end">Actions</th>
        </tr>
      </thead>
      <tbody>
        {{#each categories}}
          <tr>
            <td class="d-flex align-items-center gap-2">
              {{#if this.image}}
                <img src="{{this.image}}" class="admin-thumb" alt="{{this.name}}">
              {{else}}
                <div class="admin-thumb bg-light d-flex align-items-center justify-content-center">
                  <i class="bi bi-image text-muted"></i>
                </div>
              {{/if}}
              <span>{{this.name}}</span>
            </td>
            <td class="text-muted small">{{this.slug}}</td>
            <td>{{this.productCount}}</td>
            <td class="text-end">
              <a href="/admin/categories/{{this.id}}/edit" class="btn btn-sm btn-outline-secondary">
                <i class="bi bi-pencil"></i>
              </a>
              <form method="POST" action="/admin/categories/{{this.id}}/delete" class="d-inline" data-confirm="Delete this category?">
                {{> csrf}}
                <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
              </form>
            </td>
          </tr>
        {{else}}
          <tr><td colspan="4" class="text-center text-muted py-4">No categories yet.</td></tr>
        {{/each}}
      </tbody>
    </table>
  </div>
</div>
