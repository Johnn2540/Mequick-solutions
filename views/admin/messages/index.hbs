<div class="card border-0 shadow-sm">
  <div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
      <thead class="table-light">
        <tr>
          <th></th>
          <th>Name</th>
          <th>Subject</th>
          <th>Received</th>
          <th class="text-end">Actions</th>
        </tr>
      </thead>
      <tbody>
        {{#each messages}}
          <tr class="{{#unless this.isRead}}fw-semibold{{/unless}}">
            <td>
              {{#unless this.isRead}}<span class="badge text-bg-primary">New</span>{{/unless}}
            </td>
            <td>{{this.name}}</td>
            <td>{{#if this.subject}}{{this.subject}}{{else}}<span class="text-muted">(no subject)</span>{{/if}}</td>
            <td class="small text-muted">{{this.createdAt}}</td>
            <td class="text-end">
              <a href="/admin/messages/{{this.id}}" class="btn btn-sm btn-outline-secondary">
                <i class="bi bi-eye"></i>
              </a>
            </td>
          </tr>
        {{else}}
          <tr><td colspan="5" class="text-center text-muted py-4">No messages yet.</td></tr>
        {{/each}}
      </tbody>
    </table>
  </div>
</div>

{{> pagination baseUrl="/admin/messages"}}
