<div class="d-flex justify-content-between align-items-center mb-4">
  <h6 class="text-muted mb-0">{{brands.length}} brands</h6>
  <a href="/admin/brands/new" class="btn btn-primary"><i class="bi bi-plus-circle me-1"></i>Add Brand</a>
</div>

<div class="card border-0 shadow-sm">
  <div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
      <thead class="table-light">
        <tr>
          <th>Brand</th>
          <th>Slug</th>
          <th>Products</th>
          <th class="text-end">Actions</th>
        </tr>
      </thead>
      <tbody>
        {{#each brands}}
          <tr>
            <td class="d-flex align-items-center gap-2">
              {{#if this.logo}}
                <img src="{{this.logo}}" class="admin-thumb" alt="{{this.name}}">
              {{else}}
                <div class="admin-thumb bg-light d-flex align-items-center justify-content-center">
                  <i class="bi bi-tag text-muted"></i>
                </div>
              {{/if}}
              <span>{{this.name}}</span>
            </td>
            <td class="text-muted small">{{this.slug}}</td>
            <td>{{this.productCount}}</td>
            <td class="text-end">
              <a href="/admin/brands/{{this.id}}/edit" class="btn btn-sm btn-outline-secondary">
                <i class="bi bi-pencil"></i>
              </a>
              <form method="POST" action="/admin/brands/{{this.id}}/delete" class="d-inline" onsubmit="return confirm('Delete this brand?');">
                {{> csrf}}
                <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
              </form>
            </td>
          </tr>
        {{else}}
          <tr><td colspan="4" class="text-center text-muted py-4">No brands yet.</td></tr>
        {{/each}}
      </tbody>
    </table>
  </div>
</div>
