<div class="row">
  <div class="col-lg-6">
    <form method="POST" action="{{formAction}}" enctype="multipart/form-data">
      {{> csrf}}
      <div class="card border-0 shadow-sm">
        <div class="card-body">
          <div class="mb-3">
            <label for="name" class="form-label">Brand Name *</label>
            <input type="text" id="name" name="name" class="form-control" value="{{brand.name}}" required>
          </div>

          <div class="mb-3">
            {{#if brand.logo}}
              <img src="{{brand.logo}}" class="admin-image-preview d-block mb-2" alt="{{brand.name}}">
            {{/if}}
            <label for="logo" class="form-label">{{#if brand.logo}}Replace Logo{{else}}Brand Logo{{/if}}</label>
            <input type="file" id="logo" name="logo" class="form-control" accept="image/png,image/jpeg,image/webp,image/avif">
          </div>

          <button type="submit" class="btn btn-primary px-4">{{#if brand}}Update Brand{{else}}Create Brand{{/if}}</button>
          <a href="/admin/brands" class="btn btn-outline-secondary px-4">Cancel</a>
        </div>
      </div>
    </form>
  </div>
</div>
