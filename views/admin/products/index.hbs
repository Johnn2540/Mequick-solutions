<div class="d-flex justify-content-between align-items-center mb-4">
  <form method="GET" action="/admin/products" class="d-flex gap-2">
    <input type="text" name="q" class="form-control" placeholder="Search products..." value="{{q}}" style="width: 280px;">
    <button type="submit" class="btn btn-outline-secondary"><i class="bi bi-search"></i></button>
  </form>
  <a href="/admin/products/new" class="btn btn-primary"><i class="bi bi-plus-circle me-1"></i>Add Product</a>
</div>

<div class="card border-0 shadow-sm">
  <div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
      <thead class="table-light">
        <tr>
          <th>Product</th>
          <th>Category</th>
          <th>Brand</th>
          <th>Price</th>
          <th>Availability</th>
          <th class="text-end">Actions</th>
        </tr>
      </thead>
      <tbody>
        {{#each products}}
          <tr>
            <td class="d-flex align-items-center gap-2">
              {{#if this.images.[0].url}}
                <img src="{{this.images.[0].url}}" class="admin-thumb" alt="{{this.name}}">
              {{else}}
                <div class="admin-thumb bg-light d-flex align-items-center justify-content-center">
                  <i class="bi bi-image text-muted"></i>
                </div>
              {{/if}}
              <span>{{this.name}}</span>
              {{#if this.featured}}<span class="badge text-bg-primary">Featured</span>{{/if}}
            </td>
            <td>{{this.category.name}}</td>
            <td>{{#if this.brand.name}}{{this.brand.name}}{{else}}<span class="text-muted">—</span>{{/if}}</td>
            <td>
              {{formatCurrency this.price}}
              {{#if this.showPrice}}
                <span class="badge text-bg-success-subtle text-success d-block d-xl-inline mt-1 mt-xl-0">Public</span>
              {{else}}
                <span class="badge text-bg-secondary-subtle text-secondary d-block d-xl-inline mt-1 mt-xl-0">Hidden</span>
              {{/if}}
            </td>
            <td>
              {{#eq this.availability 'IN_STOCK'}}<span class="badge text-bg-success">In Stock</span>{{/eq}}
              {{#eq this.availability 'OUT_OF_STOCK'}}<span class="badge text-bg-secondary">Out of Stock</span>{{/eq}}
              {{#eq this.availability 'PREORDER'}}<span class="badge text-bg-warning">Pre-order</span>{{/eq}}
            </td>
            <td class="text-end">
              <a href="/admin/products/{{this.id}}/edit" class="btn btn-sm btn-outline-secondary">
                <i class="bi bi-pencil"></i>
              </a>
              <form method="POST" action="/admin/products/{{this.id}}/delete" class="d-inline" data-confirm="Delete this product? This cannot be undone.">
                {{> csrf}}
                <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
              </form>
            </td>
          </tr>
        {{else}}
          <tr><td colspan="6" class="text-center text-muted py-4">No products found.</td></tr>
        {{/each}}
      </tbody>
    </table>
  </div>
</div>

{{> pagination baseUrl="/admin/products" filters=(hash q=q)}}
