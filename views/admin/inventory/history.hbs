<div class="mb-4">
  <a href="/admin/inventory" class="text-decoration-none small"><i class="bi bi-arrow-left me-1"></i>Back to Inventory</a>
</div>

<div class="card border-0 shadow-sm mb-4">
  <div class="card-body d-flex flex-wrap justify-content-between align-items-center gap-3">
    <div>
      <h5 class="fw-bold mb-1">{{product.name}}</h5>
      {{#if product.sku}}<span class="text-muted small">SKU: {{product.sku}}</span>{{/if}}
    </div>
    <div class="text-end">
      <div class="fs-4 fw-bold">{{product.stockQuantity}}</div>
      <div class="text-muted small">Current Stock (threshold {{product.lowStockThreshold}})</div>
    </div>
  </div>
</div>

<div class="card border-0 shadow-sm">
  <div class="card-header bg-white"><h6 class="fw-bold mb-0">Stock Change History</h6></div>
  <div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
      <thead class="table-light">
        <tr>
          <th>Date</th>
          <th>Type</th>
          <th>Change</th>
          <th>Resulting Stock</th>
          <th>Note</th>
          <th>By</th>
        </tr>
      </thead>
      <tbody>
        {{#each logs}}
          <tr>
            <td class="text-muted small">{{formatDate this.createdAt}}</td>
            <td><span class="badge text-bg-secondary">{{this.changeType}}</span></td>
            <td class="{{#gt this.quantityChange 0}}text-success{{/gt}}">
              {{#gt this.quantityChange 0}}+{{/gt}}{{this.quantityChange}}
            </td>
            <td>{{this.quantityAfter}}</td>
            <td class="text-muted small">{{#if this.note}}{{this.note}}{{else}}—{{/if}}</td>
            <td class="text-muted small">{{#if this.user.name}}{{this.user.name}}{{else}}System{{/if}}</td>
          </tr>
        {{else}}
          <tr><td colspan="6" class="text-center text-muted py-4">No stock changes recorded yet.</td></tr>
        {{/each}}
      </tbody>
    </table>
  </div>
</div>

{{> pagination baseUrl=(concat "/admin/inventory/" product.id "/history") filters=(hash)}}
