<section class="py-5">
  <div class="container">
    <div class="row g-5">
      <!-- Gallery -->
      <div class="col-lg-6">
        {{#if product.images.length}}
          <div id="productGallery" class="carousel slide border rounded-3 overflow-hidden mb-3" data-bs-ride="false">
            <div class="carousel-inner">
              {{#each product.images}}
                <div class="carousel-item {{#eq @index 0}}active{{/eq}}">
                  <img src="{{this.url}}" class="d-block w-100 product-gallery-img" alt="{{../product.name}}">
                </div>
              {{/each}}
            </div>
            {{#gt product.images.length 1}}
              <button class="carousel-control-prev" type="button" data-bs-target="#productGallery" data-bs-slide="prev">
                <span class="carousel-control-prev-icon"></span>
              </button>
              <button class="carousel-control-next" type="button" data-bs-target="#productGallery" data-bs-slide="next">
                <span class="carousel-control-next-icon"></span>
              </button>
            {{/gt}}
          </div>
        {{else}}
          <div class="product-gallery-placeholder d-flex align-items-center justify-content-center border rounded-3 mb-3">
            <i class="bi bi-image display-1 text-muted"></i>
          </div>
        {{/if}}
      </div>

      <!-- Details -->
      <div class="col-lg-6">
        {{#if product.category.name}}
          <a href="/categories/{{product.category.slug}}" class="text-uppercase small text-primary fw-semibold text-decoration-none">
            {{product.category.name}}
          </a>
        {{/if}}
        <h1 class="fw-bold mt-2 mb-3">{{product.name}}</h1>

        <div class="d-flex align-items-center gap-3 mb-3">
          {{#eq product.availability 'IN_STOCK'}}<span class="badge text-bg-success">In Stock</span>{{/eq}}
          {{#eq product.availability 'OUT_OF_STOCK'}}<span class="badge text-bg-secondary">Out of Stock</span>{{/eq}}
          {{#eq product.availability 'PREORDER'}}<span class="badge text-bg-warning">Pre-order</span>{{/eq}}
          {{#if product.sku}}<span class="text-muted small">SKU: {{product.sku}}</span>{{/if}}
          {{#if product.brand.name}}<span class="text-muted small">Brand: {{product.brand.name}}</span>{{/if}}
        </div>

        <p class="h4 text-primary fw-bold mb-4">{{formatCurrency product.price}}</p>

        {{#if product.description}}
          <p class="text-muted mb-4">{{product.description}}</p>
        {{/if}}

        <div class="d-flex flex-wrap gap-3 mb-4">
          <a
            href="{{productEnquiryLink @root.company.whatsapp product.name}}"
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn-success btn-lg px-4"
          >
            <i class="bi bi-whatsapp me-2"></i>Enquire on WhatsApp
          </a>
          <a href="/request-quote?product={{product.slug}}" class="btn btn-danger btn-lg px-4">
            <i class="bi bi-file-earmark-text me-2"></i>Request a Quote
          </a>
        </div>

        {{#if product.specifications}}
          <div class="card border-0 shadow-sm">
            <div class="card-body">
              <h6 class="fw-bold mb-3"><i class="bi bi-list-check me-2"></i>Specifications</h6>
              <p class="mb-0 text-muted" style="white-space: pre-line;">{{product.specifications}}</p>
            </div>
          </div>
        {{/if}}
      </div>
    </div>

    <!-- Related Products -->
    {{#if relatedProducts.length}}
      <div class="mt-5 pt-4 border-top">
        <h3 class="fw-bold mb-4">Related Products</h3>
        <div class="row g-3">
          {{#each relatedProducts}}
            {{> product_card}}
          {{/each}}
        </div>
      </div>
    {{/if}}
  </div>
</section>
