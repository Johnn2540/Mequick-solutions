<section class="py-5">
  <div class="container text-center py-5">
    <i class="bi bi-exclamation-triangle display-1 text-danger"></i>
    <h1 class="display-4 fw-bold mt-4">Something Went Wrong</h1>
    <p class="lead text-muted mb-2">We're sorry, an unexpected error occurred on our end. Please try again shortly.</p>
    {{#if message}}
      <p class="small text-muted"><code>{{message}}</code></p>
    {{/if}}
    <div class="d-flex justify-content-center gap-3 mt-4">
      <a href="/" class="btn btn-primary px-4"><i class="bi bi-house-door me-2"></i>Back to Home</a>
      <a href="/contact" class="btn btn-outline-primary px-4"><i class="bi bi-envelope me-2"></i>Contact Support</a>
    </div>
  </div>
</section>
