<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{#if title}}{{title}} | {{company.name}}{{else}}{{company.name}} — Medical Equipment Supplier{{/if}}</title>

  <meta name="description" content="{{#if metaDescription}}{{metaDescription}}{{else}}{{company.name}} supplies quality medical equipment, laboratory products, hospital furniture, surgical instruments, and healthcare consumables across Kenya.{{/if}}">
  <meta name="theme-color" content="#1f95d3">

  <!-- Open Graph -->
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="{{company.name}}">
  <meta property="og:title" content="{{#if title}}{{title}} | {{company.name}}{{else}}{{company.name}}{{/if}}">
  <meta property="og:description" content="{{#if metaDescription}}{{metaDescription}}{{else}}Quality medical equipment and healthcare supplies across Kenya.{{/if}}">

  <link rel="icon" href="/images/favicon.ico">

  <!-- Bootstrap 5 + Icons -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  {{> fonts}}

  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

  {{> navbar}}
  {{> breadcrumbs}}
  {{> flash}}

  <main>
    {{{body}}}
  </main>

  {{> footer}}

  <!-- Sticky social rail — docks to the left edge on desktop/tablet; on
       mobile it repositions above the WhatsApp FAB instead (see
       .social-rail in style.css) so it never sits over card content in
       the site's tight 2-column mobile grid. -->
  <div class="social-rail">
    <a
      href="{{company.social.facebook}}"
      class="social-rail-link social-rail-facebook"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Follow us on Facebook"
    >
      <i class="bi bi-facebook"></i>
    </a>
    <a
      href="{{company.social.instagram}}"
      class="social-rail-link social-rail-instagram"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Follow us on Instagram"
    >
      <i class="bi bi-instagram"></i>
    </a>
  </div>

  <!-- WhatsApp floating action button -->
  <a
    href="{{waLink company.whatsapp}}"
    class="whatsapp-fab"
    target="_blank"
    rel="noopener noreferrer"
    aria-label="Chat with us on WhatsApp"
  >
    <i class="bi bi-whatsapp"></i>
  </a>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/main.js"></script>
</body>
</html>
