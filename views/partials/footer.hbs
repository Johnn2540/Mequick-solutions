<footer class="footer-main bg-dark text-white pt-5 pb-3 mt-5">
  <div class="footer-accent-bar"></div>
  <div class="container">
    <div class="row gy-4">
      <div class="col-lg-4 col-md-6">
        <h5 class="d-flex align-items-center gap-2 mb-3">
          <img src="/images/logo.png" alt="{{company.name}}" class="navbar-logo">
          {{company.name}}
        </h5>
        <p class="text-white-50">
          A trusted supplier of high-quality medical equipment, laboratory products, hospital furniture,
          and healthcare consumables in Kenya.
        </p>
        <div class="d-flex gap-2">
          <a href="{{waLink company.whatsapp}}" class="footer-social-link footer-social-whatsapp" target="_blank" rel="noopener noreferrer" aria-label="Chat with us on WhatsApp"><i class="bi bi-whatsapp"></i></a>
          <a href="{{company.social.facebook}}" class="footer-social-link footer-social-facebook" target="_blank" rel="noopener noreferrer" aria-label="Follow us on Facebook"><i class="bi bi-facebook"></i></a>
          <a href="{{company.social.instagram}}" class="footer-social-link footer-social-instagram" target="_blank" rel="noopener noreferrer" aria-label="Follow us on Instagram"><i class="bi bi-instagram"></i></a>
        </div>
      </div>

      <div class="col-lg-2 col-md-6">
        <h6 class="footer-heading mb-3">Quick Links</h6>
        <ul class="list-unstyled footer-links">
          <li><a href="/">Home</a></li>
          <li><a href="/products">Products</a></li>
          <li><a href="/categories">Categories</a></li>
          <li><a href="/about">About Us</a></li>
          <li><a href="/#testimonials">Testimonials</a></li>
          <li><a href="/services">Services</a></li>
          <li><a href="/contact">Contact</a></li>
        </ul>
      </div>

      <div class="col-lg-3 col-md-6">
        <h6 class="footer-heading mb-3">Categories</h6>
        <ul class="list-unstyled footer-links">
          <li><a href="/categories/theatre-icu-equipment">Theatre &amp; ICU Equipment</a></li>
          <li><a href="/categories/laboratory-equipment-reagents">Laboratory Equipment</a></li>
          <li><a href="/categories/surgical-instruments">Surgical Instruments</a></li>
          <li><a href="/categories/personal-protective-equipment-ppe">PPE &amp; Safety Products</a></li>
        </ul>
      </div>

      <div class="col-lg-3 col-md-6">
        <h6 class="footer-heading mb-3">Contact Us</h6>
        <ul class="list-unstyled footer-links">
          <li class="d-flex align-items-start gap-2 mb-2">
            <span class="footer-icon-chip"><i class="bi bi-geo-alt-fill"></i></span>
            <span class="pt-1">{{company.address}}</span>
          </li>
          <li class="d-flex align-items-start gap-2 mb-2">
            <span class="footer-icon-chip"><i class="bi bi-telephone-fill"></i></span>
            <a href="tel:{{company.phone}}" class="pt-1">{{company.phone}}</a>
          </li>
          <li class="d-flex align-items-start gap-2">
            <span class="footer-icon-chip"><i class="bi bi-envelope-fill"></i></span>
            <a href="mailto:{{company.email}}" class="pt-1 text-break">{{company.email}}</a>
          </li>
        </ul>

        <div class="footer-hours mt-3">
          <div class="d-flex justify-content-between small">
            <span class="text-white-50">Mon – Sat</span>
            <span class="fw-semibold">8:00 AM – 6:00 PM</span>
          </div>
          <div class="d-flex justify-content-between small">
            <span class="text-white-50">Sunday</span>
            <span class="fw-semibold">Closed</span>
          </div>
        </div>
      </div>
    </div>

    <hr class="border-secondary my-4">

    <div class="d-flex flex-column flex-md-row justify-content-between align-items-center small text-white-50 gap-2">
      <span>&copy; {{year}} {{company.name}}. All rights reserved.</span>
      <div class="d-flex align-items-center gap-3">
        <span>Nairobi, Kenya</span>
        <a href="#" class="footer-back-to-top">
          Back to Top<i class="bi bi-arrow-up-short"></i>
        </a>
      </div>
    </div>
  </div>
</footer>
