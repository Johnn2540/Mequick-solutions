<footer class="footer-main bg-dark text-white pt-5 pb-3 mt-5">
  <div class="container">
    <div class="row gy-4">
      <div class="col-lg-4 col-md-6">
        <h5 class="d-flex align-items-center gap-2 mb-3">
          <i class="bi bi-heart-pulse-fill text-primary"></i>{{company.name}}
        </h5>
        <p class="text-white-50">
          A trusted supplier of high-quality medical equipment, laboratory products, hospital furniture,
          and healthcare consumables in Kenya.
        </p>
        <div class="d-flex gap-3 fs-5">
          <a href="{{waLink company.whatsapp}}" class="footer-social-link" target="_blank" rel="noopener noreferrer" aria-label="WhatsApp"><i class="bi bi-whatsapp"></i></a>
          <a href="#" class="footer-social-link" aria-label="Facebook"><i class="bi bi-facebook"></i></a>
          <a href="#" class="footer-social-link" aria-label="Instagram"><i class="bi bi-instagram"></i></a>
          <a href="#" class="footer-social-link" aria-label="LinkedIn"><i class="bi bi-linkedin"></i></a>
        </div>
      </div>

      <div class="col-lg-2 col-md-6">
        <h6 class="mb-3">Quick Links</h6>
        <ul class="list-unstyled footer-links">
          <li><a href="/">Home</a></li>
          <li><a href="/products">Products</a></li>
          <li><a href="/categories">Categories</a></li>
          <li><a href="/about">About Us</a></li>
          <li><a href="/services">Services</a></li>
          <li><a href="/contact">Contact</a></li>
        </ul>
      </div>

      <div class="col-lg-3 col-md-6">
        <h6 class="mb-3">Categories</h6>
        <ul class="list-unstyled footer-links">
          <li><a href="/categories/theatre-icu-equipment">Theatre &amp; ICU Equipment</a></li>
          <li><a href="/categories/laboratory-equipment-reagents">Laboratory Equipment</a></li>
          <li><a href="/categories/surgical-instruments">Surgical Instruments</a></li>
          <li><a href="/categories/personal-protective-equipment-ppe">PPE &amp; Safety Products</a></li>
        </ul>
      </div>

      <div class="col-lg-3 col-md-6">
        <h6 class="mb-3">Contact Us</h6>
        <ul class="list-unstyled footer-links">
          <li class="d-flex gap-2 mb-2">
            <i class="bi bi-geo-alt-fill mt-1"></i>
            <span>{{company.address}}</span>
          </li>
          <li class="d-flex gap-2 mb-2">
            <i class="bi bi-telephone-fill mt-1"></i>
            <a href="tel:{{company.phone}}">{{company.phone}}</a>
          </li>
          <li class="d-flex gap-2">
            <i class="bi bi-envelope-fill mt-1"></i>
            <a href="mailto:{{company.email}}">{{company.email}}</a>
          </li>
        </ul>
      </div>
    </div>

    <hr class="border-secondary my-4">

    <div class="d-flex flex-column flex-md-row justify-content-between align-items-center small text-white-50 gap-2">
      <span>&copy; {{year}} {{company.name}}. All rights reserved.</span>
      <span>Nairobi, Kenya</span>
    </div>
  </div>
</footer>
