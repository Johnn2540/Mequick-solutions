<div class="col-6 col-md-4 col-lg-3">
  <div class="card product-card h-100 border-0 shadow-sm">
    <a href="/products/{{this.slug}}" class="product-card-img-wrap d-block position-relative">
      {{#if this.images.[0].url}}
        <img src="{{this.images.[0].url}}" class="card-img-top" alt="{{this.name}}" loading="lazy">
      {{else}}
        <div class="product-card-img-placeholder d-flex align-items-center justify-content-center">
          <i class="bi bi-image text-muted fs-1"></i>
        </div>
      {{/if}}
      {{#if this.featured}}
        <span class="badge bg-primary product-badge">Featured</span>
      {{/if}}
    </a>
    <div class="card-body d-flex flex-column">
      {{#if this.category.name}}
        <span class="small text-uppercase text-muted mb-1">{{this.category.name}}</span>
      {{/if}}
      <h6 class="card-title mb-1">
        <a href="/products/{{this.slug}}" class="text-decoration-none text-primary stretched-link">{{this.name}}</a>
      </h6>
      {{#if this.brand.name}}
        <p class="small text-muted mb-2">{{this.brand.name}}</p>
      {{/if}}
      <div class="d-flex flex-wrap justify-content-between align-items-center gap-1 mb-3">
        <span class="fw-semibold text-primary">{{formatCurrency this.price}}</span>
        {{#eq this.availability 'IN_STOCK'}}
          <span class="badge text-bg-success">In Stock</span>
        {{/eq}}
        {{#eq this.availability 'OUT_OF_STOCK'}}
          <span class="badge text-bg-secondary">Out of Stock</span>
        {{/eq}}
        {{#eq this.availability 'PREORDER'}}
          <span class="badge text-bg-warning">Pre-order</span>
        {{/eq}}
      </div>
      <!-- Sits above the card's stretched-link overlay (see .product-card-actions
           in style.css) so these stay independently clickable instead of the
           whole-card link swallowing every click. Stacked below `md` — at the
           2-per-row phone/tablet width these cards are too narrow for two
           side-by-side buttons to read comfortably. -->
      <div class="mt-auto d-flex flex-column flex-md-row gap-2 product-card-actions">
        <a href="/products/{{this.slug}}" class="btn btn-primary btn-sm flex-fill">View Details</a>
        <a href="/request-quote?product={{this.slug}}" class="btn btn-danger btn-sm flex-fill">Request Quote</a>
      </div>
    </div>
  </div>
</div>
